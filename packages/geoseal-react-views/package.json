{
  "name": "@geoseal/react-views",
  "version": "0.1.1",
  "description": "Embeddable React component that renders a live Geoseal shift + location view (map, geofence rings, worker track, event timeline, and AI closeout) from a single Geoseal Views embed token.",
  "private": false,
  "license": "Apache-2.0",
  "author": "Geoseal",
  "homepage": "https://geoseal.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoseal/sdks.git",
    "directory": "packages/geoseal-react-views"
  },
  "bugs": {
    "url": "https://github.com/geoseal/sdks/issues"
  },
  "keywords": [
    "geoseal",
    "geofence",
    "location",
    "tracking",
    "shift",
    "react",
    "mapbox",
    "embed",
    "live-view"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "mapbox-gl": ">=2.9.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "@types/mapbox-gl": "^2.7.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "mapbox-gl": "^2.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
