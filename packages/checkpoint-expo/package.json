{
  "name": "@geoseal/expo",
  "version": "0.2.1",
  "description": "Geoseal location / geofence / ingest SDK for Expo (SDK 51+). A config plugin wiring the iOS/Android background-location config plus a thin re-export of @geoseal/react-native. The SDK is a sensor; all detection logic runs server-side.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./geofence": {
      "types": "./dist/geofence.d.ts",
      "react-native": "./src/geofence.ts",
      "import": "./dist/geofence.js",
      "default": "./dist/geofence.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "plugin/",
    "app.plugin.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p plugin/tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p plugin/tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "node --test test/plugin-transforms.test.mjs",
    "clean": "rm -rf dist plugin/build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "expo",
    "expo-config-plugin",
    "react-native",
    "geofence",
    "location",
    "background-location",
    "geoseal"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoseal/sdks.git"
  },
  "homepage": "https://geoseal.dev",
  "bugs": {
    "url": "https://github.com/geoseal/sdks/issues"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "react": "*",
    "react-native": "*",
    "@geoseal/react-native": "^0.2.0"
  },
  "dependencies": {
    "@expo/config-plugins": "^8.0.0 || ^9.0.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "react-native": "0.76.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
