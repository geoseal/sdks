{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "strict": true,
    "noUnusedLocals": true,
    "declaration": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": [
    "common.ts",
    "index.ios.ts",
    "index.android.ts",
    "geofence.ios.ts",
    "geofence.android.ts",
    "index.d.ts",
    "geofence.d.ts",
    "references.d.ts",
    "typings/**/*.d.ts"
  ]
}
