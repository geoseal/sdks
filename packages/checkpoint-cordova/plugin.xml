<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android"
        id="checkpoint-cordova-plugin"
        version="0.2.0">

  <name>Geoseal</name>
  <description>Geoseal location / geofence / ingest SDK for Apache Cordova (iOS + Android). A thin bridge over the Geoseal native cores (CheckpointCore pod / dev.checkpoint:checkpoint-core AAR); all detection logic runs server-side.</description>
  <license>Apache-2.0</license>
  <keywords>cordova,geofence,location,background-location,geoseal</keywords>
  <repo>https://github.com/geoseal/sdks.git</repo>

  <engines>
    <engine name="cordova-android" version=">=12.0.0" />
    <!-- The Swift bridge targets the Cordova 8 plugin API (non-optional
         CDVPluginResult initializers + the CDVCommandStatus Swift enum). -->
    <engine name="cordova-ios" version=">=8.0.0" />
  </engines>

  <!-- window.Checkpoint = the Checkpoint facade methods (init / isConfigured /
       setTrackingMode / getTrackingMode / getTrackingDirective /
       setDeviceTrackingMode) at the top level, plus every named export
       (NativeGeofence, mintDeviceToken, pullArmedFences, …) namespaced.
       www/checkpoint.js is GENERATED by `npm run build` (esbuild) from
       src/index.ts, which single-sources the REST/presence layer from
       '@geoseal/capacitor/core'. -->
  <js-module src="www/checkpoint.js" name="checkpoint">
    <clobbers target="Checkpoint" />
  </js-module>

  <platform name="ios">
    <config-file target="config.xml" parent="/*">
      <feature name="CheckpointGeofence">
        <param name="ios-package" value="CheckpointCordova" />
      </feature>
      <preference name="SwiftVersion" value="5" />
      <!-- CheckpointCore's podspec floor (ios.deployment_target 14.0); the
           cordova-ios default (13.0) makes pod resolution fail without this. -->
      <preference name="deployment-target" value="14.0" />
    </config-file>

    <source-file src="ios/CheckpointCordova.swift" />

    <!-- The native engine. CheckpointCore is live on the CocoaPods trunk, so the
         pod below resolves from the CDN during `cordova platform add ios` — no
         Podfile edits. (First install on a machine with a stale CDN cache may
         need one `pod install --repo-update` in platforms/ios.) -->
    <podspec>
      <config>
        <source url="https://cdn.cocoapods.org/" />
      </config>
      <pods use-frameworks="true">
        <pod name="CheckpointCore" spec="~> 0.1" />
      </pods>
    </podspec>

    <!-- The APP owns its Info.plist usage strings (Cordova convention: the plugin
         must not overwrite user-facing copy). Region wakes + the continuous
         stream require, in the app's config.xml:

           <edit-config file="*-Info.plist" mode="merge" target="NSLocationWhenInUseUsageDescription">
             <string>Your on-site check-in reason here.</string>
           </edit-config>
           <edit-config file="*-Info.plist" mode="merge" target="NSLocationAlwaysAndWhenInUseUsageDescription">
             <string>Your background-arrival reason here.</string>
           </edit-config>
           <edit-config file="*-Info.plist" mode="merge" target="UIBackgroundModes">
             <array><string>location</string></array>
           </edit-config>

         (NSLocationAlwaysUsageDescription may be added for pre-iOS-11 tooling
         compatibility; iOS 11+ reads the AndWhenInUse key.) See README "iOS
         setup" — including the AppDelegate cold-relaunch revive hook. -->
  </platform>

  <platform name="android">
    <config-file target="res/xml/config.xml" parent="/*">
      <feature name="CheckpointGeofence">
        <param name="android-package" value="com.checkpoint.cordova.CheckpointCordova" />
      </feature>
    </config-file>

    <source-file src="android/CheckpointCordova.java" target-dir="src/com/checkpoint/cordova" />

    <!-- The native engine (AAR). Its library manifest already declares the
         location/notification permissions and the engine's receivers/services
         (com.checkpoint.capacitor.*) — the manifest merger brings them into the
         app; no config-file manifest edits are needed here. -->
    <framework src="dev.checkpoint:checkpoint-core:0.1.0" />
    <!-- Pre-publish resolution only (mavenLocal) — see the file's comment. -->
    <framework src="android/checkpoint.gradle" custom="true" type="gradleReference" />
  </platform>
</plugin>
