{
  "name": "@geoseal/capacitor",
  "version": "0.2.0",
  "description": "Geoseal location / geofence / ingest SDK for Capacitor (iOS + Android). The SDK is a sensor; all detection logic runs server-side.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./geofence": {
      "types": "./dist/geofence.d.ts",
      "import": "./dist/geofence.js",
      "default": "./dist/geofence.js"
    },
    "./contract/checkpoint-contract.json": "./contract/checkpoint-contract.json",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoseal/sdks.git",
    "directory": "packages/checkpoint-capacitor"
  },
  "files": [
    "dist/",
    "src/",
    "contract/",
    "core.js",
    "core.d.ts",
    "geofence.js",
    "geofence.d.ts",
    "ios/Sources/",
    "ios/CheckpointCoreFramework.xcodeproj/",
    "android/src/",
    "android/build.gradle",
    "android-core/build.gradle",
    "android-core/settings.gradle",
    "android-core/gradle.properties",
    "android-core/gradlew",
    "android-core/gradlew.bat",
    "android-core/gradle/",
    "Package.swift",
    "CheckpointIrlCapacitor.podspec",
    "GeosealCapacitor.podspec",
    "CheckpointCore.podspec",
    "react-native.config.cjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/pure.test.mjs test/fences.test.mjs test/contract.test.mjs",
    "generate:contract": "npm run build && node scripts/generate-contract.mjs",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "keywords": [
    "capacitor",
    "geofence",
    "location",
    "background-location",
    "geoseal"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0 <9"
  },
  "peerDependenciesMeta": {
    "@capacitor/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@capacitor/core": "^7.4.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "capacitorPlatforms": {
    "android": {
      "minSdk": 23,
      "compileSdk": 35
    }
  },
  "homepage": "https://geoseal.dev"
}
